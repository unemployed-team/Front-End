# Kakao Maps & Auth
NEXT_PUBLIC_KAKAO_APP_KEY=your_kakao_javascript_key
NEXT_PUBLIC_KAKAO_REST_API_KEY=your_kakao_rest_api_key

# Backend API (PostGIS + 공공데이터 파이프라인)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# OAuth redirect URIs
NEXT_PUBLIC_KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao/callback
NEXT_PUBLIC_NAVER_CLIENT_ID=your_naver_client_id
NEXT_PUBLIC_NAVER_REDIRECT_URI=http://localhost:3000/auth/naver/callback
