# Kakao Maps & Auth
NEXT_PUBLIC_KAKAO_APP_KEY=your_kakao_javascript_key
NEXT_PUBLIC_KAKAO_REST_API_KEY=your_kakao_rest_api_key

# Backend API
# 로컬 개발 (CORS 우회): Next.js 프록시 사용
NEXT_PUBLIC_API_BASE_URL=/api-proxy
BACKEND_API_URL=http://54.116.153.193:8080
# 백엔드 CORS 설정 후 직접 호출 시:
# NEXT_PUBLIC_API_BASE_URL=http://54.116.153.193:8080
# true로 설정하면 mock 데이터 사용 (로컬 UI만 확인할 때)
NEXT_PUBLIC_USE_MOCK=false

# OAuth 없이 임시 로그인 (개발용 — /login 에 "개발용 임시 로그인" 버튼 표시)
NEXT_PUBLIC_ENABLE_DEV_LOGIN=true

# OAuth redirect URIs (Google Console 등록값과 완전히 동일해야 함)
# 운영: JavaScript origin https://safe-room.kro.kr
NEXT_PUBLIC_KAKAO_REDIRECT_URI=http://localhost:3000/auth/kakao/callback
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=https://safe-room.kro.kr/auth/google
# 로컬 OAuth 테스트 시 (Google Console에 별도 등록 필요):
# NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google
