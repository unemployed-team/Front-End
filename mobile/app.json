{
  "expo": {
    "name": "SafeRoom AI",
    "slug": "saferoom-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "saferoom",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0d9488"
    },
    "ios": {
      "bundleIdentifier": "com.saferoom.ai",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "package": "com.saferoom.ai",
      "adaptiveIcon": {
        "backgroundColor": "#0d9488"
      },
      "usesCleartextTraffic": true,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
