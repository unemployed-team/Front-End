# EC2 백엔드 (공인 IP — Wi‑Fi와 무관하게 폰에서 접근 가능)
EXPO_PUBLIC_API_BASE_URL=http://54.116.153.193:8080
EXPO_PUBLIC_USE_MOCK=false
EXPO_PUBLIC_ENABLE_DEV_LOGIN=true

# OAuth — 백엔드 Secrets와 동일한 공개 키 (백엔드 팀에게 REST API 키 / Google Client ID 요청)
EXPO_PUBLIC_KAKAO_REST_API_KEY=your_kakao_rest_api_key
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
# 모바일 Google redirect (Google Console·백엔드 GOOGLE_REDIRECT_URI와 동일)
# EXPO_PUBLIC_GOOGLE_REDIRECT_URI=https://safe-room.kro.kr/auth/google
